{
  "name": "codediff-studio",
  "version": "0.1.0",
  "description": "A lightweight desktop code editor with file diff support.",
  "main": "./out/main/index.js",
  "type": "module",
  "author": "CodeDiff Studio",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "pack:mac:universal": "npm run build && electron-builder --mac dir --universal",
    "dist:mac:universal": "npm run build && electron-builder --mac dmg zip --universal",
    "dist:win": "npm run build && electron-builder --win nsis zip --x64",
    "dist:all": "npm run build && electron-builder --mac dmg zip --universal --win nsis zip --x64",
    "preview": "electron-vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.2",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "studio.codediff.app",
    "productName": "CodeDiff Studio",
    "files": [
      "out/**/*",
      "src/renderer/src/assets/support/**/*"
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": "AppImage",
      "category": "Development"
    }
  }
}
