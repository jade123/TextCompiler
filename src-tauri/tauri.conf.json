{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "文本阅读器",
  "version": "0.1.0",
  "identifier": "com.jade.textreader",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "文本阅读器",
        "width": 1320,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "windows": {
      "wix": null,
      "nsis": null
    }
  }
}
